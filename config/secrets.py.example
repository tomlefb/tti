"""
Secrets template. Copy this file to `secrets.py` and fill in your values.
The real `secrets.py` is gitignored — never commit it.

How to obtain each value:

TELEGRAM_BOT_TOKEN
    1. Open Telegram, search for @BotFather.
    2. Send /newbot, follow prompts.
    3. BotFather replies with a token like "123456789:ABCdef..." — paste here.

TELEGRAM_CHAT_ID
    1. After creating the bot, send any message to it from your account.
    2. Visit https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates in a browser.
    3. Find "chat":{"id":XXXXXXXXX,...} — that integer is your chat ID.

MT5_LOGIN, MT5_PASSWORD, MT5_SERVER
    From your FundedNext (or other broker) account email / dashboard.
    The MT5 terminal must already be logged in for the Python API to read data;
    these are kept as fallbacks for explicit reconnection.
"""

TELEGRAM_BOT_TOKEN = "PASTE_YOUR_BOT_TOKEN_HERE"
TELEGRAM_CHAT_ID = 0   # integer

MT5_LOGIN = 0          # integer (your account number)
MT5_PASSWORD = "PASTE_YOUR_MT5_PASSWORD_HERE"
MT5_SERVER = "FundedNext-Server"   # exact server name from MT5 login screen
