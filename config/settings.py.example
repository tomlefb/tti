# -----------------------------------------------------------------------------
# Watched instruments
# -----------------------------------------------------------------------------
# Symbol names must match those exposed by the MT5 terminal (varies by broker).
# Adjust if your broker uses different symbol names (e.g., "XAUUSD.r" instead of "XAUUSD").

WATCHED_PAIRS = [
    "XAUUSD",
    "NDX100",   # may be "USTEC", "NAS100", "NQ100", etc. depending on broker
    "EURUSD",
    "GBPUSD",
]

# -----------------------------------------------------------------------------
# Sessions (Paris time)
# -----------------------------------------------------------------------------
# Format: (start_hour, start_minute, end_hour, end_minute)

SESSION_ASIA = (2, 0, 6, 0)
KILLZONE_LONDON = (9, 0, 12, 0)
KILLZONE_NY = (15, 30, 18, 0)

# -----------------------------------------------------------------------------
# Detection: SWING POINTS (calibrated rule)
# -----------------------------------------------------------------------------
# See `docs/07_DETECTION_PHILOSOPHY.md` section 1.2 and section 3.
# These default values are placeholders and MUST be calibrated against
# operator-marked reference charts before being trusted in production.

# Lookback: number of candles each side that must be lower (for high) or higher (for low).
# 1 = strict 3-bar fractal (very noisy). 2-3 = more selective.
SWING_LOOKBACK_H4 = 2
SWING_LOOKBACK_H1 = 2
SWING_LOOKBACK_M5 = 2

# Significant-swing amplitude filter — calibrated PER timeframe.
# A swing on TF X only counts if its distance to the previous opposite-type
# swing on TF X is >= the multiplier × ATR(14) on TF X.
#
# Per-TF calibration acknowledges that H4 swings should be more selective
# than H1 swings: an H4 pivot represents a higher-order structural event
# and should not be triggered by intra-day retracements.
#
# Sprint 1 (2026-04-28): single shared key calibrated to 1.0 against 38
# operator-annotated sessions. H4 result P=87.1%, R=77.1%, F1=81.8%; H1
# plateaus at F1≈54% (geometric pivots vs major tradeable liquidity —
# design choice, not a tuning failure).
#
# Sprint 3 amendment (2026-04-28): split into per-TF keys after the
# diagnostic dive on XAUUSD 2025-10-15 showed the unified 1.0 multiplier
# triggers H4 pivots on intra-day retracements, killing bias on clean
# trending days. H4 retuned via `calibration/run_grid_search_h4_only.py`.
# H1 default kept from Sprint 1 (geometric — design choice).
# H4 = 1.3: see calibration/runs/{2026-04-28T14-38-09Z}_grid_search_h4_only.md.
# (2, 1.0) is the F1-best at 81.8% but (2, 1.3) is within 0.6 pp at 81.2%
# AND has 8/19 sessions passing the docs/07 §3 step 4 80/80 bar (vs 7/19
# for 1.0 — best of the grid). Per spec tie-break preference for higher
# selectivity on H4 (rationale: fewer false bias signals on intra-day
# retracements, addressing the 2025-10-15 XAUUSD diagnostic dive).
MIN_SWING_AMPLITUDE_ATR_MULT_H4 = 1.3
MIN_SWING_AMPLITUDE_ATR_MULT_H1 = 1.0  # unchanged from Sprint 1
MIN_SWING_AMPLITUDE_ATR_MULT_M5 = 1.0  # default — M5 swings used in MSS detection

# Number of confirmed significant swings to consider when computing daily bias.
BIAS_SWING_COUNT = 4

# Daily-bias confirmation requirement.
# False (Sprint 3 default): H4 structure alone determines bias.
# True  (legacy / Sprint 1): H4 AND H1 must agree.
#
# Per Sprint 3 diagnostic, H1 confirmation rejected valid bias signals on
# clean trending days; H4-only bias yields significantly more tradeable
# slots without losing signal quality. See FINAL_swing_calibration.md
# Sprint 3 amendment for rationale.
BIAS_REQUIRE_H1_CONFIRMATION = False

# -----------------------------------------------------------------------------
# Detection: SWING LEVELS — multi-TF confluence (Sprint 2 — heuristic)
# -----------------------------------------------------------------------------
# Per `calibration/runs/FINAL_swing_calibration.md`, the operator's strategy
# treats liquidity strength as a function of multi-TF confluence: an H1 swing
# that ALSO shows up as an H4 swing is "major"; an isolated H1 pivot is
# "minor". `mark_swing_levels()` in `src/detection/liquidity.py` implements
# the H4 ∩ H1 promotion using the keys below.
#
# These are docs/07 §1.3 heuristic defaults — to be revisited based on
# Sprint 2 empirical results.

# Time tolerance for matching an H4 swing to an H1 swing, expressed in
# H4 candles. 2 H4 candles = ±8h either side of the H4 swing.
H4_H1_TIME_TOLERANCE_CANDLES_H4 = 2

# Price tolerance for the same match, as a fraction of the swing price.
# 0.001 = 0.1% — same value used by the calibration matching harness.
H4_H1_PRICE_TOLERANCE_FRACTION = 0.001

# How many of the most recent H4 significant swings to consider as
# candidates for promotion. H1 minor swings are taken from the last
# 2 × this count (more numerous on the lower timeframe).
SWING_LEVELS_LOOKBACK_COUNT = 5

# -----------------------------------------------------------------------------
# Detection: SWEEP (calibrated rule)
# -----------------------------------------------------------------------------

# Number of candles after the wick during which the close must return
# back across the swept level. 1 = same candle only; 2-3 = grace period.
SWEEP_RETURN_WINDOW_CANDLES = 2

# Sweep deduplication (Sprint 3 — heuristic; see docs/07 §1.3).
# A single structural sweep on M5 often emits multiple Sweep objects
# (consecutive candles re-sweeping the same level, multiple co-located
# levels swept by the same candle). `deduplicate_sweeps` collapses
# clusters of same-direction, same-level, same-time-window sweeps to
# the deepest one. Without this, downstream MSS/FVG detection re-runs
# on dozens of essentially identical sweep events per killzone.
#
# 30 minutes covers most multi-touch sweep events on M5 within a single
# killzone phase. 0.1% matches `H4_H1_PRICE_TOLERANCE_FRACTION` (Sprint
# 2) and the calibration harness tolerance — keeping the same relative
# tolerance across the codebase avoids cross-tuning surprises.
SWEEP_DEDUP_TIME_WINDOW_MINUTES = 30
SWEEP_DEDUP_PRICE_TOLERANCE_FRACTION = 0.001

# -----------------------------------------------------------------------------
# Detection: MSS (calibrated rule)
# -----------------------------------------------------------------------------

# MSS displacement: candle body must be >= multiplier * mean(body of previous N candles).
MSS_DISPLACEMENT_MULTIPLIER = 1.5
MSS_DISPLACEMENT_LOOKBACK = 20

# -----------------------------------------------------------------------------
# Detection: FVG (calibrated rule for size; pure logic for geometry)
# -----------------------------------------------------------------------------

FVG_ATR_PERIOD = 14
FVG_MIN_SIZE_ATR_MULTIPLIER = 0.3

# -----------------------------------------------------------------------------
# Detection: SETUP THRESHOLDS (mostly heuristic)
# -----------------------------------------------------------------------------

MIN_RR = 3.0
A_PLUS_RR_THRESHOLD = 4.0

# Partial-exit TP target. The strategy targets the opposing-liquidity
# pool (TP_runner, can yield RR 3 to 18+). For variance reduction the
# system additionally exposes TP1 capped at this RR — operator's
# convention is to scale 50% out at TP1 and run the rest to TP_runner.
# When TP_runner_rr <= this cap, TP1 == TP_runner (no partial benefit).
# 5R is the standard SMC partial mark; revisit if backtests suggest
# a tighter (3-4R) or looser (6-8R) cap fits the operator's outcomes.
PARTIAL_TP_RR_TARGET = 5.0

# -----------------------------------------------------------------------------
# Per-instrument config (calibrated rules)
# -----------------------------------------------------------------------------
# Sweep buffer: minimum wick excursion beyond a level to count as a sweep.
# Equal H/L tolerance: max distance between two levels to consider them "equal".
# SL buffer: extra distance beyond sweep extreme for stop loss.
# Units are price units (USD for XAU, points for indices, decimal price for forex).

INSTRUMENT_CONFIG = {
    "XAUUSD": {
        "sweep_buffer": 1.0,           # 1 USD
        "equal_hl_tolerance": 0.5,     # 0.5 USD
        "sl_buffer": 1.0,              # 1 USD beyond sweep extreme
    },
    "NDX100": {
        "sweep_buffer": 5.0,           # 5 points
        "equal_hl_tolerance": 3.0,
        "sl_buffer": 5.0,
    },
    "EURUSD": {
        "sweep_buffer": 0.00050,       # 5 pips
        "equal_hl_tolerance": 0.00030,
        "sl_buffer": 0.00050,
    },
    "GBPUSD": {
        "sweep_buffer": 0.00050,
        "equal_hl_tolerance": 0.00030,
        "sl_buffer": 0.00050,
    },
}

