PRE_KILLZONE_BIAS_LEAD_MINUTES = 5

# Daily outcome reconciliation runs once at this Paris-local hour.
OUTCOME_RECONCILIATION_HOUR_PARIS = 23

# -----------------------------------------------------------------------------
# MT5 robustness (Sprint 6)
# -----------------------------------------------------------------------------

# Exponential-backoff parameters for fetch_ohlc and get_recent_trades.
# Defaults yield retry delays of 1s, 2s, 4s, 8s, 16s ⇒ 31s total before
# the cycle gives up and logs an error. Connect failures are NOT retried —
# the scheduler bootstrap aborts.
MT5_RETRY_MAX_ATTEMPTS = 5
MT5_RETRY_BASE_DELAY_SECONDS = 1.0

# -----------------------------------------------------------------------------
# Manual safety override (Sprint 6)
# -----------------------------------------------------------------------------

# Set to True ONLY after the operator has manually reviewed a
# max-loss-critical breach and decided to resume. The hard-stops layer
# refuses to lift the suspension on its own — see docs/05 §"Hard stops".
MAX_LOSS_OVERRIDE = False

# -----------------------------------------------------------------------------
# Sprint 7 — Auto-execution
# -----------------------------------------------------------------------------
# Sprint 7 enables auto-execution on the demo account so no setup is missed
# during operator unavailability. The detection pipeline is unchanged; the
# new ``src/execution/`` module places, manages, and closes orders via
# ``mt5.order_send``. See docs/04 §"Auto-execution rules" for the full
# rule set, docs/05 for the safety stack, and docs/03 Sprint 7 for the
# rollout plan.

# Master switch. False reverts the system to Sprint 6 notifications-only
# behaviour. Default True on the demo account; the operator must perform
# a separate config change to point the system at a live account.
AUTO_TRADING_ENABLED = True

# Magic number written on every order placed by the system. Identifies
# our orders in MT5 logs and lets recovery / lifecycle filter on a
# stable owner key.
MAGIC_NUMBER = 7766

# Optional dry-run flag — when True, place_order logs what it WOULD send
# to MT5 without actually calling order_send. Useful on the Mac dev box
# where the MetaTrader5 package is not installed.
AUTO_TRADING_DRY_RUN = False

# Fraction of account balance closed at TP1 when the lifecycle detects
# the partial level was crossed. The remainder rides to TP_runner with
# SL pulled to break-even.
TP1_PARTIAL_FRACTION = 0.5

# Optional hard ceiling on per-trade risk in USD. ``None`` = no cap;
# RISK_PER_TRADE_FRACTION × balance is the only constraint.
MAX_RISK_PER_TRADE_USD = None

# Spread anomaly multiplier. When live spread > typical × multiplier,
# the order_manager logs a row to ``spread_anomalies`` but DOES NOT
# block the trade. ``typical_spread`` lives under INSTRUMENT_CONFIG
# above; instruments without a typical_spread skip the check.
SPREAD_ANOMALY_MULTIPLIER = 3.0

# Position-lifecycle polling cadence (seconds). 30s gives a tight enough
# loop to catch TP1 transitions without hammering MT5. The job is
# scheduled with an ``IntervalTrigger`` and runs at all hours (cheap
# read-only check when no positions are open).
LIFECYCLE_CHECK_INTERVAL_SEC = 30

# Path to the kill-switch file. When the file exists, place_order is
# hard-disabled (lifecycle and end-of-killzone cleanup keep running so
# already-open positions still close cleanly). The default is the
# project-root ``KILL_SWITCH`` file.
#
# To pause auto-execution manually:
#     touch KILL_SWITCH
# To resume:
#     rm KILL_SWITCH
KILL_SWITCH_PATH = "KILL_SWITCH"

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

LOG_FILE = "logs/system.log"
LOG_MAX_BYTES = 10 * 1024 * 1024  # 10 MB
LOG_BACKUP_COUNT = 5
LOG_LEVEL = "INFO"

# -----------------------------------------------------------------------------
# Database / Journal (Sprint 5)
# -----------------------------------------------------------------------------

DB_PATH = "data/journal.db"

# Outcome tracker (Sprint 5)
# Time window (in minutes) used to match an MT5 trade to a journaled
# Taken setup. The operator may take 5–20 minutes to click Taken and
# place the order, so ±30 covers the realistic spread without
# admitting unrelated trades on the same symbol.
OUTCOME_MATCH_WINDOW_MINUTES = 30

# -----------------------------------------------------------------------------
# Notification (Sprint 4)
# -----------------------------------------------------------------------------

# Where notification chart PNGs are written. Gitignored by default. The
# bot reads from disk and ships the file to Telegram; cleanup is the
# operator's responsibility (or a Sprint 6+ janitor task).
CHART_OUTPUT_DIR = "runtime_charts"

# M5 candles included in the notification chart, before / after the MSS
# confirm candle. 80 + 10 ≈ 7.5h of context — operator can re-eyeball
# the bias structure without leaving Telegram.
CHART_LOOKBACK_CANDLES_M5 = 80
CHART_LOOKFORWARD_CANDLES_M5 = 10

# Manual smoke-test polling window in scripts/test_notification.py. The
# operator clicks Taken/Skipped within this many seconds; if no click,
# the script exits gracefully so the operator can re-run.
TELEGRAM_CALLBACK_TIMEOUT_SECONDS = 60
