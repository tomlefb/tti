MAX_TRADES_PER_DAY = 2
MAX_TRADES_PER_PAIR_PER_DAY = 2
MAX_CONSECUTIVE_SL_PER_DAY = 2

# News blackout (manual switch for v1; integrate calendar later).
NEWS_BLACKOUT_TODAY = False

# -----------------------------------------------------------------------------
# Scheduler
# -----------------------------------------------------------------------------

DETECTION_INTERVAL_MINUTES = 5  # Run detection every 5 min during killzones.
HEARTBEAT_AT_KILLZONE_START = True
HEARTBEAT_AT_KILLZONE_CLOSE_IF_EMPTY = True

# Lead time (minutes before a killzone start) at which the pre-killzone
