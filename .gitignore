# --- Secrets and local config (only the .example versions are committed) ---
config/secrets.py
config/settings.py

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments ---
venv/
.venv/
env/
.env

# --- Tooling caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# --- Logs ---
logs/*.log
logs/*.log.*

# --- Calibration runs ---
# Auto-generated timestamped reports are noise; the manually-curated
# FINAL_*.md canonical records are committed. Ignore directory contents
# rather than the directory itself, so the exception below can match.
calibration/runs/*
!calibration/runs/FINAL_*.md

# --- Parquet artifacts in calibration runs only; fixtures are committed ---
calibration/runs/**/*.parquet

# --- SQLite journal (data lives on the Windows host, not in repo) ---
data/
*.db
*.sqlite
*.sqlite3

# --- Runtime chart screenshots ---
runtime_charts/

# --- OS noise ---
.DS_Store
Thumbs.db

# --- Editors ---
.vscode/
.idea/
*.swp
*.swo

# --- Extended Databento fixtures (large, regenerated locally) ---
tests/fixtures/historical_extended/raw/
tests/fixtures/historical_extended/processed/

# Sprint 7 — auto-execution kill switch (operator-managed; not versioned)
KILL_SWITCH
